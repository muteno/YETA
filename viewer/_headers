# Cloudflare Pages 캐시 규칙 — 정적 뷰어는 매 로드 재검증(no-cache)해서
# 새 배포가 하드새로고침 없이 바로 반영되게. (api/yeta 응답은 코드가 no-store 자체 부착.)
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache
/tokens.css
  Cache-Control: no-cache
# 연락처 vCard(사진 임베드) — 안드로이드가 "연락처에 추가"로 열게 정확 MIME 명시
/assets/contacts/haeun.vcf
  Content-Type: text/x-vcard; charset=utf-8
  Content-Disposition: attachment; filename="haeun.vcf"
